# Get this from console.anthropic.com — API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Pick your own long random string — this is the password Jarvis will require
# from any device before it responds. Generate one with: openssl rand -hex 24
AUTH_TOKEN=change-this-to-a-long-random-string

# Which model Jarvis uses. Swap to claude-opus-4-8 for harder tasks,
# or claude-haiku-4-5-20251001 for cheaper/faster everyday use.
MODEL=claude-sonnet-5

# Absolute path to the folder Jarvis is allowed to read/write.
# Defaults to ./workspace if not set. Keep this scoped — don't point it at
# your whole home directory.
WORKSPACE_DIR=

PORT=3000

# For self-editing to commit to GitHub instead of local disk (required once this
# runs on Render, since local file writes don't survive a redeploy there). Leave
# blank to keep using local disk — fine for testing on your own PC.
# GITHUB_TOKEN: a Personal Access Token with write access to this repo's contents
#   (a fine-grained token scoped to just this one repo is safer than a classic token).
# GITHUB_REPO: "owner/repo-name", e.g. "jacko/jarvis-web"
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_BRANCH=main

